  "keyFeatures": [
    "Contact management with detailed notes and context",
    "Event scheduling and invitation tracking",
    "Automated follow-up task creation",
    "Team workspaces with role-based access",
    "Web push notifications",
    "Interaction logging for relationship building",
    "Multi-tenant architecture",
    "Authentication with social login support"
  ],
  "publicApiSurface": [
    "GET/POST /contacts - Manage contacts",
    "GET/POST /events - Create and manage events",
    "POST /events/:id/invitations - Invite contacts to events",
    "PATCH /invitations/:id - Update invitation status",
    "GET /follow_up_tasks - View follow-up tasks",
    "POST /interaction_logs - Log interactions",
    "POST /accounts - Create workspaces",
    "POST /team_invitations - Invite team members",
    "POST /sign_in - User authentication",
    "POST /sign_up - User registration",
    "GET /notifications - View notifications",
    "POST /web_push_subscriptions - Subscribe to push notifications"
  ]
